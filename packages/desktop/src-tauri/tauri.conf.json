{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MyMind",
  "version": "1.0.0",
  "identifier": "com.mymind.app",
  "build": {
    "frontendDist": "../web/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm --filter @mymind/web dev",
    "beforeBuildCommand": "pnpm --filter @mymind/web build"
  },
  "app": {
    "windows": [
      {
        "title": "MyMind",
        "width": 1280,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"]
  }
}
